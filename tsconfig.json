{
    "compilerOptions": {
        "allowJs": true,
        "baseUrl": ".",
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": false,
        "target": "ES2020",
        "types": ["vite/client"],
        "paths": {
            "@/*": ["resources/js/*"]
        }
    },
    "include": ["resources/js/**/*.ts", "resources/js/**/*.tsx", "resources/js/**/*.jsx"]
}
